# ── Relay environment ──────────────────────────────────────────────
RELAY_ENVIRONMENT=production
PUBLIC_BASE_URL=https://relay.example.com/v1
INTERNAL_API_KEY=replace-with-strong-random-value

# ── Postgres ───────────────────────────────────────────────────────
# DATABASE_URL is set automatically by docker-compose.yml.
# Only override here if pointing at an external Postgres instance.
# DATABASE_URL=postgresql+psycopg://postgres:password@host:5432/herald
POSTGRES_PASSWORD=change-me

# ── Auth / pairing ────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
PAIRING_CODE_TTL_SECONDS=900
PHONE_PAIRING_CODE_TTL_SECONDS=600
PHONE_PAIRING_MAX_ATTEMPTS_PER_CODE=5
PHONE_PAIRING_MAX_ATTEMPTS_PER_IP=5
PHONE_PAIRING_RATE_LIMIT_WINDOW_SECONDS=300
HOST_ENROLLMENT_CODE_TTL_SECONDS=900
DEFAULT_USER_DISPLAY_NAME=Herald User

# ── Connector / Herald agent ──────────────────────────────────────
HERALD_ADAPTER=connector
HERALD_COMMAND=hermes
HERALD_WORKDIR=
HERALD_PROVIDER=
HERALD_MODEL=
HERALD_TOOLSETS=
HERALD_SOURCE=tool
HERALD_HISTORY_LIMIT=20
CONNECTOR_SETUP_SECRET=
CONNECTOR_SYNC_WAIT_SECONDS=25
CONNECTOR_JOB_LEASE_SECONDS=180
CONNECTOR_HEARTBEAT_TIMEOUT_SECONDS=30
CONNECTOR_IDLE_POLL_INTERVAL_SECONDS=0.1

# ── APNs (optional — omit all to disable push) ───────────────────
# Use APNS_KEY_PATH for local dev, APNS_KEY_CONTENTS for Docker/production.
# APNS_KEY_PATH=/path/to/AuthKey.p8
# APNS_KEY_CONTENTS=-----BEGIN PRIVATE KEY-----\n...
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=net.fihonline.herald
APNS_ENVIRONMENT=production
APP_PRESENCE_STALE_SECONDS=120
